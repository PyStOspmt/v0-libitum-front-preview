{
    "semi": false,
    "singleQuote": false,
    "tabWidth": 4,
    "printWidth": 128,
    "trailingComma": "all",
    "plugins": ["@trivago/prettier-plugin-sort-imports"],
    "importOrder": [
        "<THIRD_PARTY_MODULES>",
        "^@/components/(.*)$",
        "^@/features/(.*)$",
        "^@/lib/(.*)$",
        "^@/app/(.*)$",
        "^[./]"
    ],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true
}
